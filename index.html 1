<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>BSc Results</title>

<style>

body{
font-family:Arial;
background:#f4f6f9;
text-align:center;
padding:40px;
}

input{
padding:10px;
font-size:16px;
}

button{
padding:10px 20px;
font-size:16px;
background:#2c3e50;
color:white;
border:none;
cursor:pointer;
}

table{
margin:auto;
margin-top:20px;
border-collapse:collapse;
width:70%;
background:white;
}

th,td{
border:1px solid #ddd;
padding:8px;
text-align:center;
}

.pass{
background:#2ecc71;
color:white;
}

.fail{
background:#e74c3c;
color:white;
}

</style>

</head>

<body>

<h2>B.Sc Computer Science Results</h2>

<p>Enter Registration Number</p>

<input type="text" id="regno">
<button onclick="showResult()">Get Result</button>

<div id="result"></div>

<script>

let students={

"250701":{
name:"Student 1",
marks:[67,45,34,21,29,38,30]
},

"250702":{
name:"Student 2",
marks:[18,25,30,40,32,35,30]
}

};

function showResult(){

let reg=document.getElementById("regno").value;

let student=students[reg];

if(!student){
document.getElementById("result").innerHTML="Result not found";
return;
}

let subjects=["English","Telugu","AI","CF","CF Lab","C","C Lab"];

let total=0;

let html="<table><tr><th>Subject</th><th>Marks</th></tr>";

for(let i=0;i<subjects.length;i++){

let m=student.marks[i];

total+=m;

let cls=m>=21?"pass":"fail";

html+="<tr><td>"+subjects[i]+"</td><td class='"+cls+"'>"+m+"</td></tr>";

}

html+="<tr><td><b>Total</b></td><td><b>"+total+"</b></td></tr>";

html+="</table>";

document.getElementById("result").innerHTML=html;

}

</script>

</body>
</html>
